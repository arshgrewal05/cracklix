
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and role-based status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "dob": { "type": "string", "format": "date" },
        "address": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "ADMIN", "CONTENT_MANAGER", "STUDENT"] },
        "state": { "type": "string", "enum": ["Punjab"] },
        "targetExam": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "description": "The ID of the active pass or 'Free'" },
        "passExpiryDate": { "type": "string", "format": "date-time" },
        "pinnedExams": { "type": "array", "items": { "type": "string" } },
        "unlockedMocks": { "type": "array", "items": { "type": "string" }, "description": "Specific mocks unlocked for this user manually." }
      },
      "required": ["id", "name", "email", "phone", "role"]
    },
    "Pass": {
      "title": "Institutional Pass",
      "description": "A tiered access node.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "durationDays": { "type": "number" },
        "description": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "displayOrder": { "type": "number" },
        "type": { "type": "string", "enum": ["FREE", "PREMIUM"] },
        "adFree": { "type": "boolean" },
        "active": { "type": "boolean" }
      }
    },
    "Category": {
      "title": "Exam Category",
      "description": "Top-level exam grouping (e.g., Banking, Punjab Govt).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "displayOrder": { "type": "number" },
        "highlight": { "type": "string" }
      }
    },
    "CurrentAffairHubItem": {
      "title": "Current Affair Hub Item",
      "description": "Daily, weekly, or monthly current affairs package.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "month": { "type": "string" },
        "year": { "type": "string" },
        "language": { "type": "string" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["DAILY", "WEEKLY", "MONTHLY", "SPECIAL"] },
        "pdfUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["PUBLISHED", "DRAFT"] },
        "quizId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" }
    },
    "/passes/{passId}": {
      "schema": { "$ref": "#/backend/entities/Pass" }
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/backend/entities/Category" }
    },
    "/current_affairs_hub/{caId}": {
      "schema": { "$ref": "#/backend/entities/CurrentAffairHubItem" }
    }
  }
}
