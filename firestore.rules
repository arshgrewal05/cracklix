
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'arshdeepgrewal1122@gmail.com' ||
        getUserData().role in ['ADMIN', 'SUPER_ADMIN']
      );
    }

    function isContentTeam() {
      return isAdmin() || (isAuthenticated() && getUserData().role in ['CONTENT_MANAGER', 'QUESTION_REVIEWER']);
    }

    function isSupport() {
      return isAdmin() || (isAuthenticated() && getUserData().role == 'SUPPORT_AGENT');
    }

    // --- Enterprise Data Rules ---
    match /boards/{id} { allow read: if true; allow write: if isAdmin(); }
    match /exams/{id} { allow read: if true; allow write: if isAdmin(); }
    match /subjects/{id} { allow read: if true; allow write: if isContentTeam(); }
    
    match /questions/{id} { 
      allow read: if isAuthenticated(); 
      allow create: if isContentTeam();
      allow update: if isContentTeam();
      allow delete: if isAdmin();
    }

    match /mocks/{id} { 
      allow read: if true; 
      allow create, update: if isContentTeam();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || isSupport());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /settings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /current_affairs/{id} { allow read: if true; allow write: if isContentTeam(); }
    match /notifications/{id} { allow read: if true; allow write: if isContentTeam(); }
    match /pyqs/{id} { allow read: if true; allow write: if isContentTeam(); }
    match /reports/{id} { allow create: if isAuthenticated(); allow read, update: if isSupport(); }
    match /audit_logs/{id} { allow read: if isAdmin(); allow create: if isContentTeam(); }

    match /{document=**} {
      allow read, write: if request.auth.token.email == 'arshdeepgrewal1122@gmail.com';
    }
  }
}
