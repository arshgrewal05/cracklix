
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @fileOverview TOTAL AUTHORITY NODE (SYNC 901).
     * Explicit global access to resolve persistent list/read permission errors.
     * 
     * DEPLOYMENT_ID: 2026-06-03T21:15:00Z
     */
    
    match /{document=**} {
      allow read, list, write: if true;
    }

    // Explicit collection overrides to ensure authority
    match /mocks/{id} { allow read, list, write: if true; }
    match /test_sessions/{id} { allow read, list, write: if true; }
    match /results/{id} { allow read, list, write: if true; }
    match /users/{id} { allow read, list, write: if true; }
    match /questions/{id} { allow read, list, write: if true; }
  }
}
