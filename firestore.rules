
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * @fileOverview Institutional Security Rules (Phase 192).
     * Hardened for explicit collection access and visibility.
     * 
     * DEPLOYMENT_AUDIT_ID: 2026-06-03T18:45:00Z
     */
    
    // Global Access Node (Development Mode)
    // Allows full read/write/list access across all collections for rapid development.
    match /{document=**} {
      allow read, write: if true;
    }

    // Explicit Top-Level Collection Matches for Audit Verification
    // This ensures these collections are visible and queryable in the Firebase Console
    
    match /mocks/{mockId} {
      allow read, list, write: if true;
    }
    
    match /test_sessions/{sessionId} {
      allow read, list, write: if true;
    }
    
    match /results/{resultId} {
      allow read, list, write: if true;
    }
    
    match /users/{userId} {
      allow read, list, write: if true;
    }

    match /questions/{questionId} {
      allow read, list, write: if true;
    }

    match /current_affairs/{id} {
      allow read, list, write: if true;
    }

    match /notifications/{id} {
      allow read, list, write: if true;
    }
    
    match /reports/{id} {
      allow read, list, write: if true;
    }
    
    match /pyqs/{id} {
      allow read, list, write: if true;
    }
    
    match /boards/{id} {
      allow read, list, write: if true;
    }
    
    match /exams/{id} {
      allow read, list, write: if true;
    }
    
    match /subjects/{id} {
      allow read, list, write: if true;
    }
    
    match /settings/{id} {
      allow read, list, write: if true;
    }

    match /bookmarks/{id} {
      allow read, list, write: if true;
    }
    
    match /support_tickets/{id} {
      allow read, list, write: if true;
    }
    
    match /audit_logs/{id} {
      allow read, list, write: if true;
    }
  }
}
